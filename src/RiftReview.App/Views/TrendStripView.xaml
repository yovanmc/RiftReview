<UserControl x:Class="RiftReview.App.Views.TrendStripView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RiftReview.App.Converters">
    <UserControl.Resources>
        <!-- Win/loss dot converter scoped to this view -->
        <conv:BoolToBrushConverter x:Key="WinDot"
            TrueBrush="{StaticResource WinBrush}"
            FalseBrush="{StaticResource LossBrush}" />
    </UserControl.Resources>

    <Border Background="{StaticResource CardBgBrush}"
            BorderBrush="{StaticResource HairlineBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="Last 20 games"
                       Foreground="{StaticResource AccentBrush}"
                       FontWeight="SemiBold"
                       FontSize="12"
                       Margin="0,0,0,6"/>

            <!-- W/L dots -->
            <DockPanel Grid.Row="1" Margin="0,2">
                <TextBlock DockPanel.Dock="Left"
                           Text="W/L"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           Width="50"
                           VerticalAlignment="Center"/>
                <ItemsControl ItemsSource="{Binding Wins}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Ellipse Width="10" Height="10" Margin="2"
                                     Fill="{Binding Converter={StaticResource WinDot}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>

            <!-- Deaths -->
            <DockPanel Grid.Row="2" Margin="0,2">
                <TextBlock DockPanel.Dock="Left"
                           Text="Deaths"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           Width="50"
                           VerticalAlignment="Center"/>
                <ItemsControl ItemsSource="{Binding Deaths}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="11"
                                       Margin="3,0"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>

            <!-- CS@10 -->
            <DockPanel Grid.Row="3" Margin="0,2">
                <TextBlock DockPanel.Dock="Left"
                           Text="CS@10"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           Width="50"
                           VerticalAlignment="Center"/>
                <ItemsControl ItemsSource="{Binding CsAt10}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="11"
                                       Margin="3,0"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>

            <!-- Gold@15 -->
            <DockPanel Grid.Row="4" Margin="0,2">
                <TextBlock DockPanel.Dock="Left"
                           Text="Gold@15"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           Width="50"
                           VerticalAlignment="Center"/>
                <ItemsControl ItemsSource="{Binding GoldAt15}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="11"
                                       Margin="3,0"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
