<UserControl x:Class="RiftReview.App.Views.ClimbView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:RiftReview.App.Converters">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToBrushConverter x:Key="WinResultBrush"
            TrueBrush="{StaticResource WinBrush}"
            FalseBrush="{StaticResource LossBrush}"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <TextBlock Grid.Row="0"
                   Text="Climb"
                   Foreground="{StaticResource AccentBrush}"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="20,16,20,12"/>

        <!-- ═══ BODY ═══ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20,0,20,20">

                <!-- ─── Standing cards row ─── -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">

                    <!-- Solo tile -->
                    <Border CornerRadius="6"
                            Padding="16"
                            Margin="0,0,12,0"
                            MinWidth="200"
                            DataContext="{Binding Solo}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding QueueLabel}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding RankText}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SeasonRecord}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                                <TextBlock Text=" · "
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding WinRateText}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Flex tile -->
                    <Border CornerRadius="6"
                            Padding="16"
                            Margin="0,0,12,0"
                            MinWidth="200"
                            DataContext="{Binding Flex}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding QueueLabel}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding RankText}"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SeasonRecord}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                                <TextBlock Text=" · "
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding WinRateText}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- No-standing fallback -->
                    <TextBlock Text="No ranked standing yet — sync while ranked."
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAnyStanding}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>

                <!-- ─── Ranked momentum tile ─── -->
                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="6"
                        Padding="16"
                        Margin="0,16,0,0">
                    <StackPanel>

                        <!-- Streak text (colored by StreakIsPositive) -->
                        <TextBlock Text="{Binding StreakText}"
                                   FontSize="16"
                                   FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource LossBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StreakIsPositive}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource WinBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Longest streaks -->
                        <TextBlock Text="{Binding LongestStreaksText}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"
                                   Margin="0,4,0,0"/>

                        <!-- Recent-form strip -->
                        <ItemsControl ItemsSource="{Binding RecentForm}"
                                      Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="14"
                                            Height="14"
                                            CornerRadius="3"
                                            Margin="0,0,3,0"
                                            Background="{Binding Win, Converter={StaticResource WinResultBrush}}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>

                <!-- ─── LP history section ─── -->
                <StackPanel Margin="0,16,0,0">

                    <TextBlock Text="LP HISTORY — RANKED SOLO"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>

                    <TextBlock Text="{Binding LpHistoryNote}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontStyle="Italic"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,2,0,8"/>

                    <!-- Segment rows -->
                    <ItemsControl ItemsSource="{Binding SoloSegments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,8"
                                        BorderBrush="{StaticResource HairlineBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Left: WhenRange + RankRange -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding WhenRange}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="13"/>
                                            <TextBlock Text="{Binding RankRange}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="11"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Right: NetLpText (colored by IsGain) -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding NetLpText}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource LossBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsGain}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource WinBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- No-segments fallback -->
                    <TextBlock Text="Only one snapshot so far — your next sync starts the ledger."
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="12"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSoloSegments}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>

                <!-- ─── Empty state ─── -->
                <TextBlock Text="Sync while ranked to start tracking your climb."
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,24"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
