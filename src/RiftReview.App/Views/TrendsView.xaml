<UserControl x:Class="RiftReview.App.Views.TrendsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:RiftReview.App.Converters"
             xmlns:controls="clr-namespace:RiftReview.App.Controls">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Gold pill chip style for champ selector ListBox items -->
        <Style x:Key="ChampChipContainerStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="#0A0A0C"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Metric row style for the drill ListBox -->
        <Style x:Key="MetricRowContainerStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PanelBgBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16">

                <!-- Header: title -->
                <TextBlock Text="Improvement trends"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <!-- LP strip (only when LP data exists) -->
                <TextBlock Text="{Binding LpHeadline}"
                           Visibility="{Binding HasLp, Converter={StaticResource BoolToVis}}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"
                           Margin="0,0,0,16"/>

                <!-- Preparing overlay text -->
                <TextBlock Text="{Binding PrepareStatus}"
                           Visibility="{Binding IsPreparing, Converter={StaticResource BoolToVis}}"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="12"
                           FontStyle="Italic"
                           Margin="0,0,0,12"/>

                <!-- Empty state -->
                <TextBlock Text="Play more ranked games on a champ (≥ 2× the trend window) to see trends."
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,24"/>

                <!-- Non-empty content -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Champion chip selector -->
                    <TextBlock Text="CHAMPION"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <ListBox ItemsSource="{Binding Champions}"
                             SelectedItem="{Binding SelectedChampion, Mode=TwoWay}"
                             DisplayMemberPath="Name"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource ChampChipContainerStyle}"
                             Margin="0,0,0,20">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>

                    <!-- Metric trajectory rows (ListBox so row click → SelectedMetric drill) -->
                    <TextBlock Text="METRIC TRENDS"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <ListBox ItemsSource="{Binding Metrics}"
                             SelectedItem="{Binding SelectedMetric, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource MetricRowContainerStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left: DisplayName + Current -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Current}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11"/>
                                    </StackPanel>

                                    <!-- Center: Sparkline -->
                                    <controls:Sparkline Grid.Column="1"
                                                        Values="{Binding Series}"
                                                        Height="28"
                                                        Margin="8,0"/>

                                    <!-- Right: Verdict label + Delta -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" MinWidth="80">
                                        <TextBlock Text="{Binding Verdict}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsGood}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource WinBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsBad}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource LossBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Delta}"
                                                   FontSize="11"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Drill panel: larger sparkline for SelectedMetric -->
                    <Border Background="{StaticResource CardBgBrush}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,12"
                            Margin="0,16,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMetric}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel DataContext="{Binding SelectedMetric}">
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding Current}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <controls:Sparkline Values="{Binding Series}"
                                                Height="120"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
