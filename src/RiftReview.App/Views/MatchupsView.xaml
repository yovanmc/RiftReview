<UserControl x:Class="RiftReview.App.Views.MatchupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RiftReview.App.Converters">

    <UserControl.Resources>
        <!-- Win coloring for game rows (Win=True → WinBrush, False → LossBrush) -->
        <conv:BoolToBrushConverter x:Key="WinResultBrush"
            TrueBrush="{StaticResource WinBrush}"
            FalseBrush="{StaticResource LossBrush}"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Gold pill chip style for champ selector — copied verbatim from TrendsView.xaml -->
        <Style x:Key="ChampChipContainerStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="#0A0A0C"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PanelBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════ HEADER ═══════════════ -->
        <StackPanel Grid.Row="0" Margin="20,16,20,12">

            <TextBlock Text="Matchups"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <!-- Empty state -->
            <TextBlock Text="Play more ranked games (≥ 5 on a champ) to scout your matchups."
                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>

            <!-- Champion chip selector (hidden when empty) -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="CHAMPION"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <ListBox ItemsSource="{Binding Champions}"
                         SelectedItem="{Binding SelectedChampion, Mode=TwoWay}"
                         DisplayMemberPath="Name"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource ChampChipContainerStyle}"
                         Margin="0,0,0,12">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>

                <!-- Min games filter -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="min games"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <Slider Minimum="1"
                            Maximum="10"
                            Value="{Binding MinGamesFilter, Mode=TwoWay}"
                            IsSnapToTickEnabled="True"
                            TickFrequency="1"
                            Width="140"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding MinGamesFilter}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- ═══════════════ BODY: 2-column master–detail ═══════════════ -->
        <Grid Grid.Row="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40*"/>
                <ColumnDefinition Width="60*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: opponent list ─── -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,1,1,0">
                <ListBox ItemsSource="{Binding Opponents}"
                         SelectedItem="{Binding SelectedOpponent, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <DockPanel.Style>
                                    <Style TargetType="DockPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsThin}" Value="True">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DockPanel.Style>

                                <!-- Right: WinPercent + GamesLabel -->
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding WinPercent}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,0,6,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFavorable}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource WinBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsUnfavorable}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource LossBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding GamesLabel}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Left: OpponentName -->
                                <TextBlock Text="{Binding OpponentName}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- ─── RIGHT: detail pane ─── -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20,12">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedOpponent}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Heading -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap">
                            <Run Text="{Binding SelectedChampion.Name, Mode=OneWay}"/>
                            <Run Text=" vs "/>
                            <Run Text="{Binding SelectedOpponent.OpponentName, Mode=OneWay}"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding SelectedOpponent.Record}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="13"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding SelectedOpponent.WinPercent}"
                                       FontSize="13"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedOpponent.IsFavorable}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource WinBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedOpponent.IsUnfavorable}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource LossBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Metric tiles (UniformGrid 3 cols) -->
                    <UniformGrid Columns="3" Margin="0,0,0,16">
                        <!-- Gold@15 -->
                        <Border Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,6,6">
                            <StackPanel>
                                <TextBlock Text="Gold@15"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedOpponent.GoldDiff15}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <!-- CS@10 -->
                        <Border Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,6,6">
                            <StackPanel>
                                <TextBlock Text="CS@10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedOpponent.Cs10}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <!-- Deaths -->
                        <Border Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="Deaths"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedOpponent.Deaths}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <!-- KDA -->
                        <Border Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="KDA"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedOpponent.Kda}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <!-- Pre-15 -->
                        <Border Background="{StaticResource CardBgBrush}"
                                BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="Pre-15"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedOpponent.Pre15}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Games list header -->
                    <TextBlock Text="GAMES — click to open deep-dive"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <!-- Games list -->
                    <ItemsControl ItemsSource="{Binding SelectedOpponent.GameRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenDeepDiveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding MatchId}"
                                        HorizontalContentAlignment="Stretch"
                                        Cursor="Hand"
                                        Padding="0,6"
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="{StaticResource HairlineBrush}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <DockPanel>
                                        <!-- Result (colored) -->
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="{Binding Result}"
                                                   Foreground="{Binding Win, Converter={StaticResource WinResultBrush}}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Width="36"
                                                   VerticalAlignment="Center"/>
                                        <!-- Date (right) -->
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding WhenLocal}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <!-- KDA + GoldDiff15 (center) -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Kda}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12"
                                                       Margin="0,0,12,0"/>
                                            <TextBlock Text="{Binding GoldDiff15}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
