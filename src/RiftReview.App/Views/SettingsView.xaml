<UserControl x:Class="RiftReview.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Background="{StaticResource PanelBgBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16">

                <!-- Header -->
                <TextBlock Text="Settings"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,24"/>

                <!-- Match Depth section -->
                <TextBlock Text="MATCH DEPTH"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,4">
                    <Slider Minimum="{Binding MinDepth}"
                            Maximum="{Binding MaxDepth}"
                            Value="{Binding MatchDepth, Mode=TwoWay}"
                            Width="260"
                            VerticalAlignment="Center"
                            TickFrequency="10"
                            IsSnapToTickEnabled="True"/>
                    <TextBlock Text="{Binding MatchDepth}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </StackPanel>

                <TextBlock Text="Number of recent matches used for analysis (20–300)."
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           Margin="0,0,0,24"/>

                <!-- Trend Window section -->
                <TextBlock Text="TREND WINDOW"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,4">
                    <Slider Minimum="{Binding MinTrendWindow}"
                            Maximum="{Binding MaxTrendWindow}"
                            Value="{Binding TrendWindow, Mode=TwoWay}"
                            Width="260"
                            VerticalAlignment="Center"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"/>
                    <TextBlock Text="{Binding TrendWindow}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </StackPanel>

                <TextBlock Text="Games per rolling window used for trend verdicts."
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           Margin="0,0,0,24"/>

                <!-- Default Filter section -->
                <TextBlock Text="DEFAULT FILTER"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <ToggleButton Content="Ranked only"
                              IsChecked="{Binding DefaultRankedOnly, Mode=TwoWay}"
                              HorizontalAlignment="Left"
                              Padding="10,5"
                              Background="Transparent"
                              BorderBrush="{StaticResource HairlineBrush}"
                              Foreground="{StaticResource TextMutedBrush}"
                              FontSize="12"
                              Margin="0,0,0,4"/>

                <TextBlock Text="When enabled, the Champions and Review pages open in ranked-only mode by default."
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
