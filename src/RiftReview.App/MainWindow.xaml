<ui:FluentWindow x:Class="RiftReview.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:views="clr-namespace:RiftReview.App.Views"
                 xmlns:conv="clr-namespace:RiftReview.App.Converters"
                 Title="RiftReview"
                 Width="1120"
                 Height="720"
                 MinWidth="800"
                 MinHeight="560"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 Background="{StaticResource WindowBgBrush}"
                 WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <conv:BoolToBrushConverter x:Key="WinDotBrush"
            TrueBrush="{StaticResource WinBrush}"
            FalseBrush="{StaticResource LossBrush}"/>
        <conv:BoolToBrushConverter x:Key="IsErrorBrush"
            TrueBrush="{StaticResource LossBrush}"
            FalseBrush="{StaticResource TextMutedBrush}"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar Grid.Row="0" Title="RiftReview"/>

        <!-- Main content: rail (300px) + right panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT RAIL -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBgBrush}"
                    BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>

                    <!-- Header: Sync + Ranked toggle -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource CardBgBrush}"
                            BorderBrush="{StaticResource HairlineBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <ui:Button Content="Sync"
                                           Command="{Binding SyncCommand}"
                                           Appearance="Primary"
                                           Padding="12,5"
                                           FontSize="13"/>
                                <ToggleButton Content="Ranked only"
                                              IsChecked="{Binding RankedOnly, Mode=TwoWay}"
                                              Margin="8,0,0,0"
                                              Padding="8,5"
                                              Background="Transparent"
                                              BorderBrush="{StaticResource HairlineBrush}"
                                              Foreground="{StaticResource TextMutedBrush}"
                                              FontSize="12"/>
                            </StackPanel>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{Binding IsError, Converter={StaticResource IsErrorBrush}}"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Match list (with empty-state overlay) -->
                    <Grid DockPanel.Dock="Bottom">
                        <!-- Empty state hint — visible only when list is empty -->
                        <TextBlock Text="No matches yet — set your Riot key and press Sync."
                                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="16,24"/>
                    <ListBox ItemsSource="{Binding Matches}"
                             SelectedItem="{Binding SelectedMatch}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Row 1: champ + role -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <TextBlock Text="{Binding ChampionName}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"/>
                                        <TextBlock Text=" · "
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="13"/>
                                        <TextBlock Text="{Binding Role}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="13"/>
                                    </StackPanel>
                                    <!-- Row 2: result (colored) + kda + time -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding Result}"
                                                   Foreground="{Binding Win, Converter={StaticResource WinDotBrush}}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text=" · "
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12"/>
                                        <TextBlock Text="{Binding Kda}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12"/>
                                        <TextBlock Text=" · "
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12"/>
                                        <TextBlock Text="{Binding WhenLocal}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- RIGHT PANEL: trend strip (auto) + deep-dive (*) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <views:TrendStripView Grid.Row="0"
                                      DataContext="{Binding TrendStrip}"/>

                <views:DeepDiveView Grid.Row="1"
                                    DataContext="{Binding DeepDive}"/>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
