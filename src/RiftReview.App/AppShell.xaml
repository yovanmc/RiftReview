<ui:FluentWindow x:Class="RiftReview.App.AppShell"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:views="clr-namespace:RiftReview.App.Views"
                 Title="RiftReview"
                 Width="1120"
                 Height="720"
                 MinWidth="800"
                 MinHeight="560"
                 WindowBackdropType="None"
                 ExtendsContentIntoTitleBar="True"
                 Background="{StaticResource WindowBgBrush}"
                 WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tilt banner: collapses to zero height when not on tilt; spans the top. -->
        <Border x:Name="TiltBanner" Grid.Row="0"
                Padding="16,10" Margin="0"
                Visibility="Collapsed"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource HairlineBrush}">
            <Border.Resources>
                <SolidColorBrush x:Key="TiltTintBrush"    Color="#33E24A4A"/>
                <SolidColorBrush x:Key="CautionTintBrush" Color="#33C8AA6E"/>
            </Border.Resources>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TiltBannerText" Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="13" TextWrapping="Wrap"/>
                <TextBlock Grid.Column="1" Text="Open Session Health ›"
                           VerticalAlignment="Center" Margin="16,0,0,0"
                           Foreground="{StaticResource AccentBrush}" FontSize="12"/>
            </Grid>
        </Border>

        <ui:NavigationView x:Name="RootNavigation" Grid.Row="1"
                           PaneDisplayMode="LeftFluent"
                           IsPaneOpen="False">

            <ui:NavigationView.TitleBar>
                <ui:TitleBar Title="RiftReview"/>
            </ui:NavigationView.TitleBar>

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Review"
                                       TargetPageType="{x:Type views:ReviewView}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="History20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Champions"
                                       TargetPageType="{x:Type views:ChampPoolView}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Trophy20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Trends"
                                       TargetPageType="{x:Type views:TrendsView}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="DataTrending24"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Matchups"
                                       TargetPageType="{x:Type views:MatchupsView}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="PeopleSwap24"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Session Health"
                                       TargetPageType="{x:Type views:SessionHealthView}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="HeartPulse24"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Settings"
                                       TargetPageType="{x:Type views:SettingsView}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Settings20"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>

        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
